{
  "name": "CodeEditer",
  "version": "1.0.0",
  "author": "JinRui_MaoMao",
  "description": "Cross-language CodeEditer with multi-language support",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^26.6.10",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.jinrui.codeediter",
    "productName": "CodeEditer",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico",
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    }
  }
}